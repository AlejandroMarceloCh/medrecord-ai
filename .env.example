# MedRecord AI — variables de entorno.
# Copia a .env si quieres sobrescribir. .env está en .gitignore.
#
# Las de la sección "Acceso" NO son opcionales: sin usuarios, sin token y sin
# MEDRECORD_OPEN, el server se niega a arrancar. Es a propósito — arrancar sin
# autenticación deja las historias clínicas accesibles a cualquiera que alcance
# el puerto, y eso detrás de un túnel significa "a cualquiera con la URL".

# ── Acceso (obligatorio elegir uno) ──
# Admin inicial. Se crea al primer arranque si todavía no hay ningún usuario.
# Van comentadas A PROPÓSITO: un `cp .env.example .env` sin editar crearía un admin
# con una contraseña que está escrita en el repo. Descoméntalas y pon una clave real.
# MEDRECORD_ADMIN_USER=tu-usuario
# MEDRECORD_ADMIN_PASS=una-clave-larga-que-elijas-tu

# Token del dispositivo de grabación (móvil). SOLO ESCRITURA: sube audio, no lee historias.
# MEDRECORD_TOKEN=un-token-largo-y-aleatorio

# Escotilla de desarrollo: arranca SIN autenticación. Nunca en producción, nunca
# expuesto a una red. Existe para no pedir login en localhost mientras desarrollas.
# MEDRECORD_OPEN=1

# Orígenes permitidos para escribir (CSRF). Por defecto solo se acepta el mismo origen por
# el que llegó la petición, que cubre el caso normal y el del túnel. Añade aquí un dominio
# propio si sirves la web desde otro host.
# MEDRECORD_ORIGINS=https://consulta.tuclinica.pe

# Duración de la sesión del médico (default 12 h).
# SESSION_TTL_MS=43200000
# Throttle de login: bloquea tras N fallos, durante LOCK_MS.
# LOGIN_MAX_FAILS=5
# LOGIN_LOCK_MS=60000

# ── Datos y cifrado ──
# Clave maestra AES-256 (32 bytes). Se genera sola al primer arranque.
# Si se pierde, los datos cifrados son IRRECUPERABLES: respáldala (ver RESTORE.md).
# Si el archivo existe pero es inválido, el server aborta en vez de regenerarla.
# MEDRECORD_KEY_FILE=/ruta/a/.master.key
# MEDRECORD_DATA_DIR=/ruta/a/data/recordings

# Retención del audio de la consulta, en días. El audio se borra de forma segura
# (sobrescrito) N días después de firmar la historia; la nota se conserva siempre.
# El audio es dato de salud: guardarlo indefinidamente incumple el principio de
# minimización. Default 90. Poner 0 lo desactiva, y hay que quererlo.
MEDRECORD_AUDIO_RETENTION_DAYS=90

# ── Servidor ──
PORT=3000
HOST=0.0.0.0
# NODE_ENV=production   # sirve dist/ (JSX precompilado) en vez de public/

# ── LLM (Ollama local) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_TIMEOUT_MS=120000

# ── Whisper.cpp (rutas al build local) ──
# Por defecto apunta a ~/Desktop/PROYECTOS_2026/Transcripciones/whisper.cpp
# WHISPER_HOME=/ruta/a/whisper.cpp
# WHISPER_BIN=/ruta/a/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL=/ruta/a/whisper.cpp/models/ggml-large-v3.bin
# WHISPER_VAD=/ruta/a/whisper.cpp/models/ggml-silero-v5.1.2-v6.2.1-ggml.bin
WHISPER_LANG=es
# FFMPEG_BIN=ffmpeg
# WHISPER_TIMEOUT_MS=1200000
